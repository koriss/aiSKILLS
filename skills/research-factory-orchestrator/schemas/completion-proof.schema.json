{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CompletionProof",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "pipeline_version": {
      "type": "string"
    },
    "stage_count_required": {
      "type": "integer"
    },
    "stage_count_completed": {
      "type": "integer"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "counts": {
      "type": "object"
    },
    "final_delivery_allowed": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "required": [
    "task_id",
    "item_id",
    "pipeline_version",
    "stage_count_required",
    "stage_count_completed",
    "artifacts",
    "validators",
    "final_delivery_allowed"
  ]
}
