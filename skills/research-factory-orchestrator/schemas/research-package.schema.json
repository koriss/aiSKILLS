      }
    },
    "source_snapshots": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "search_ledger": {
      "type": "object"
    },
    "evidence_cards": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
