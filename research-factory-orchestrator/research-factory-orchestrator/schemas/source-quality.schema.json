{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceQuality",
  "type": "object",
  "properties": {
    "source_id": {
      "type": "string"
    },
    "origin_source_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "is_derivative": {
      "type": "boolean"
    },
    "derivative_chain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "independence_score": {
      "type": "number"
    },
    "authority_score": {
      "type": "number"
    },
    "directness_score": {
      "type": "number"
    },
    "recency_score": {
      "type": "number"
    },
    "specificity_score": {
      "type": "number"
    },
    "bias_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    }
  },
  "additionalProperties": true,
  "required": [
    "source_id"
  ]
}
