{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeContract",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "user_request": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "AUTO_COMPILE_AND_EXECUTE",
        "REPORT_FACTORY",
        "FACT_CHECK_ONLY",
        "AUDIT_EXISTING_REPORT",
        "RESUME_RUNTIME",
        "COMPILE_ONLY"
      ]
    },
    "output_profile": {
      "type": "string",
      "enum": [
        "executive_brief",
        "deep_report",
        "fact_check_report",
        "due_diligence_memo",
        "market_map",
        "risk_register",
        "timeline",
        "entity_map",
        "source_audit",
        "dataset_package",
        "report_factory_package",
        "academic_reference",
        "game_research_brief",
        "political_analysis",
        "scientific_literature_review"
      ]
    },
    "task_type": {
      "type": "string"
    },
    "project_dir": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "required": [
    "task_id",
    "title",
    "mode"
  ]
}
