{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-factory-orchestrator.local/schemas/handoff-envelope.schema.json",
  "title": "RFO phase handoff envelope (v18.5)",
  "type": "object",
  "required": [
    "from_phase",
    "to_phase",
    "payload_hash",
    "required_fields",
    "success_response",
    "failure_response",
    "timeout_ms",
    "on_failure_action",
    "prev_hash",
    "handoff_id",
    "created_at"
  ],
  "properties": {
    "from_phase": { "type": "string", "minLength": 1 },
    "to_phase": { "type": "string", "minLength": 1 },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "required_fields": { "type": "array", "items": { "type": "string" } },
    "success_response": { "type": "string" },
    "failure_response": { "type": "string" },
    "timeout_ms": { "type": "integer", "minimum": 1 },
    "on_failure_action": { "type": "string", "enum": ["block", "retry", "escalate", "clarify"] },
    "prev_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "handoff_id": { "type": "string" },
    "created_at": { "type": "string" },
    "payload": { "type": "object" }
  },
  "additionalProperties": true
}
