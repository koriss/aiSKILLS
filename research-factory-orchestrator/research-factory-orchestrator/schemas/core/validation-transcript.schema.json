{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rfo.local/schemas/v19/validation-transcript.schema.json",
  "title": "ValidationTranscript",
  "description": "REC-1: root allows extension fields; validatorResult items allow extra keys (reserved: validator_id, status, passed, blocking, issues, warnings, summary, duration_ms).",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "profile_used",
    "status",
    "validators",
    "overall_pass",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "v19.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string" },
    "item_id": { "type": "string" },
    "profile_used": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "validators": {
      "type": "array",
      "items": { "$ref": "#/$defs/validatorResult" }
    },
    "overall_pass": { "type": "boolean" },
    "all_passed": { "type": "boolean" },
    "created_at": { "type": "string", "minLength": 1 },
    "advisory_channels": {
      "type": "object",
      "description": "Optional v19.1+ advisory outputs (blinded checker, typed grounding, etc.); never affects schema_version const v19.0.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "validatorResult": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "validator_id",
        "status",
        "passed",
        "blocking",
        "issues",
        "warnings",
        "summary"
      ],
      "properties": {
        "validator_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "skipped", "crash"]
        },
        "passed": { "type": "boolean" },
        "blocking": { "type": "boolean" },
        "issues": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "summary": { "type": "string" }
      }
    }
  }
}
