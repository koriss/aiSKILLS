{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CitationLocator",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "string"
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "anchors_found": {
      "type": "integer"
    },
    "missing_anchors": {
      "type": "integer"
    }
  },
  "additionalProperties": true,
  "required": [
    "item_id",
    "citations"
  ]
}
