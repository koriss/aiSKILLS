{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProviderPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "run_id",
    "provider",
    "type",
    "payload",
    "stub_delivery",
    "real_external_delivery",
    "created_at"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "payload_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "file_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload": {
      "type": "object"
    },
    "stub_delivery": {
      "type": "boolean"
    },
    "real_external_delivery": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    }
  }
}
