{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TelegramDelivery",
  "type": "object",
  "properties": {
    "delivery_id": {
      "type": "string"
    },
    "summary_path": {
      "type": "string"
    },
    "message_plan_path": {
      "type": "string"
    },
    "message_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "validated": {
      "type": "boolean"
    }
  },
  "additionalProperties": true,
  "required": [
    "delivery_id",
    "message_files",
    "attachments",
    "validated"
  ]
}
