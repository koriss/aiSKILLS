{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReportSection",
  "type": "object",
  "properties": {
    "section_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "section_type": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "required": [
    "section_id",
    "title",
    "section_type",
    "components"
  ]
}
