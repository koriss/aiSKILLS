{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StageRecordV7",
  "type": "object",
  "properties": {
    "stage": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "complete",
        "blocked",
        "failed"
      ]
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts_created": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "validator": {
      "type": [
        "string",
        "null"
      ]
    },
    "validator_status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked",
        "not_run"
      ]
    },
    "validator_transcript_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true,
  "required": [
    "stage",
    "status",
    "required_artifacts",
    "artifacts_created",
    "validator_status"
  ]
}
