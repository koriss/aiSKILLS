{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntCoverageMatrix",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "string"
    },
    "int_families": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "single_int_lockin": {
      "type": "boolean"
    },
    "all_source_claimed": {
      "type": "boolean"
    },
    "all_source_supported": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "required": [
    "item_id",
    "int_families",
    "single_int_lockin"
  ]
}
