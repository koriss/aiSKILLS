{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "item_id": { "type": "string" },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim_id": { "type": "string" },
          "source_id": { "type": "string" },
          "direct_url": { "type": "string" },
          "local_ref": { "type": "string" },
          "evidence_anchor": { "type": "string" },
          "evidence_summary": { "type": "string" },
          "accessed_at": { "type": "string" }
        },
        "required": ["claim_id", "source_id", "evidence_anchor", "evidence_summary"]
      }
    }
  },
  "required": ["item_id", "citations"]
}
