{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FactCheck",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "string"
    },
    "claims_checked": {
      "type": "integer"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "completed_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "required": [
    "item_id",
    "claims_checked"
  ]
}
