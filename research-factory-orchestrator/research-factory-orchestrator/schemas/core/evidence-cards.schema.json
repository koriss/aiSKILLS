{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rfo.local/schemas/v19/evidence-cards.schema.json",
  "title": "EvidenceCardsBundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_cards"],
  "properties": {
    "schema_version": { "type": "string", "const": "v19.0" },
    "evidence_cards": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceCard" }
    }
  },
  "$defs": {
    "evidenceCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "source_ids",
        "extracted_fact_or_excerpt",
        "supports",
        "confidence"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "claim_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "official_statement",
            "filing",
            "dataset",
            "article",
            "interview",
            "court_record",
            "registry_record",
            "scientific_paper",
            "social_post",
            "user_video",
            "other"
          ]
        },
        "extracted_fact_or_excerpt": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "text"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["excerpt", "extracted_fact"]
            },
            "text": { "type": "string", "minLength": 1 }
          }
        },
        "anchor": { "type": "string" },
        "supports": {
          "type": "string",
          "enum": ["direct", "indirect", "contextual", "contradicts"]
        },
        "limitations": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "disputed", "unknown"]
        }
      }
    }
  }
}
