{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResumePlan",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string"
    },
    "resume_from": {
      "type": "string"
    },
    "work_units_to_retry": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "work_units_complete": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "required": [
    "task_id",
    "next_actions"
  ]
}
