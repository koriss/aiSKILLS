{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "item_id": { "type": "string" },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string" },
          "resolved": { "type": "boolean" }
        },
        "required": ["code", "message", "resolved"]
      }
    },
    "audit_passed": { "type": "boolean" }
  },
  "required": ["item_id", "errors", "audit_passed"]
}
