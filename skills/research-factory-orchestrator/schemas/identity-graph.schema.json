  "title": "IdentityGraph",
  "type": "object",
  "properties": {
    "target_person": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
