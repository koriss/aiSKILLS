{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TraceEvent",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "item_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "tool_used": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifact_changed": {
      "type": [
        "string",
        "null"
      ]
    },
    "progress": {
      "type": "boolean"
    },
    "success": {
      "type": "boolean"
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true,
  "required": [
    "timestamp",
    "state",
    "action",
    "success"
  ]
}
