{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "allowed_claims",
    "forbidden_claims"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "pass_with_limitations",
        "fail"
      ]
    },
    "allowed_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "read_coverage": {
      "type": "object"
    },
    "context_budget": {
      "type": "object"
    }
  }
}