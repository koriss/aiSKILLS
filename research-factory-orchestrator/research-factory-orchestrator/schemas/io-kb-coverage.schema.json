{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IOKBCoverage",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "string"
    },
    "kb_used": {
      "type": "boolean"
    },
    "kb_record_count": {
      "type": "integer"
    },
    "method_matches": {
      "type": "integer"
    },
    "actor_matches": {
      "type": "integer"
    },
    "doctrine_matches": {
      "type": "integer"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true,
  "required": [
    "item_id",
    "kb_used",
    "warnings"
  ]
}
