{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "artifacts",
    "updated_at"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "updated_at": {
      "type": "string"
    }
  }
}
