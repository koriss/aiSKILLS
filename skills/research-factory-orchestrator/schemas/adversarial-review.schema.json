{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AdversarialReview",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "conditional_pass",
        "blocked"
      ]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true,
  "required": [
    "item_id",
    "status"
  ]
}
