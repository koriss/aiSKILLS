{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ErrorAudit",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "string"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "errors_found": {
      "type": "integer"
    },
    "errors_fixed": {
      "type": "integer"
    }
  },
  "additionalProperties": true,
  "required": [
    "item_id",
    "errors_found"
  ]
}
