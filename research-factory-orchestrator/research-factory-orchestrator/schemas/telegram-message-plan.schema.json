{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TelegramMessagePlan",
  "type": "object",
  "properties": {
    "delivery_id": {
      "type": "string"
    },
    "parse_mode": {
      "type": "string"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "plain_text_only": {
      "type": "boolean"
    },
    "no_large_tables": {
      "type": "boolean"
    }
  },
  "additionalProperties": true,
  "required": [
    "messages",
    "attachments",
    "plain_text_only"
  ]
}
