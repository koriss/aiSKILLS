{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FailurePacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "failure_id",
    "failure_type",
    "work_unit_id",
    "subagent_id",
    "created_at",
    "next_action"
  ],
  "properties": {
    "failure_id": {
      "type": "string"
    },
    "failure_type": {
      "type": "string"
    },
    "work_unit_id": {
      "type": "string"
    },
    "subagent_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "partial_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "enum": [
        "retry",
        "replace",
        "mark_partial",
        "fail_run"
      ]
    },
    "detail": {
      "type": "string"
    }
  }
}
