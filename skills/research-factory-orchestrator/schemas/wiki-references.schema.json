{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WikiReferences",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "string"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "required": [
    "item_id",
    "references"
  ]
}
