{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeliveryManifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "run_id",
    "delivery_status",
    "attachments",
    "local_paths_exposed",
    "created_at"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "delivery_status": {
      "enum": [
        "not_queued",
        "created",
        "running",
        "ready",
        "delivering",
        "delivered",
        "stub_delivered",
        "partial_delivery",
        "partial",
        "failed",
        "cancelled",
        "content_ready_delivery_not_proven"
      ]
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "telegram_messages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "local_paths_exposed": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "stub_delivery": {
      "type": "boolean"
    },
    "real_external_delivery": {
      "type": "boolean"
    },
    "delivery_claim_allowed": {
      "type": "boolean"
    },
    "publish_allowed": {
      "type": "boolean"
    },
    "publish_reason": {
      "type": "string"
    },
    "required_outbox_events": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_acks_missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gates": {
      "type": "object"
    }
  }
}
