{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rfo.local/schemas/v19/contradiction-matrix.schema.json",
  "title": "ContradictionMatrixL2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "matrix_id", "claims_covered", "entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "v19.0" },
    "matrix_id": { "type": "string", "minLength": 1 },
    "claims_covered": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/matrixEntry" }
    }
  },
  "$defs": {
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_role",
        "interest_alignment",
        "access_level",
        "verification_mode",
        "independence",
        "corroboration"
      ],
      "properties": {
        "source_role": { "type": "string" },
        "interest_alignment": { "type": "string" },
        "access_level": { "type": "string" },
        "verification_mode": { "type": "string" },
        "independence": { "type": "string" },
        "corroboration": { "type": "string" }
      }
    },
    "matrixEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "claim_ids",
        "conflict_summary",
        "parties",
        "severity",
        "evidence_pointers",
        "rubric_facets",
        "resolution",
        "effect_on_status"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "claim_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "conflict_summary": { "type": "string", "minLength": 1 },
        "parties": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "source_ids"],
            "properties": {
              "label": {
                "type": "string",
                "description": "Neutral label (e.g. source_cluster_A), not moral role"
              },
              "source_ids": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            }
          }
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "evidence_pointers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["evidence_card_id"],
            "properties": {
              "evidence_card_id": { "type": "string" },
              "span": { "type": "string" }
            }
          }
        },
        "rubric_facets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["for_party_a", "for_party_b"],
          "properties": {
            "for_party_a": { "$ref": "#/$defs/rubric" },
            "for_party_b": { "$ref": "#/$defs/rubric" }
          }
        },
        "resolution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "notes"],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "unresolved",
                "partially_resolved",
                "resolved",
                "waived_with_justification"
              ]
            },
            "notes": { "type": "string", "minLength": 1 }
          }
        },
        "effect_on_status": {
          "type": "object",
          "additionalProperties": true,
          "description": "Per-claim status adjustments recommended after matrix review"
        }
      }
    }
  }
}
